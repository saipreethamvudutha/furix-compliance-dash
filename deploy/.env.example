# Copy to `.env` in this deploy/ directory and adjust. All have safe defaults.

# ── Database ──
PG_USER=furix
PG_PASSWORD=change-me-in-prod
PG_DBNAME=furix_compliance
PG_DBNAME_DET=furix_det

# ── Gemma / Ollama ──
# In-compose ollama by default. If Ollama runs elsewhere (e.g. your server),
# set this to that host and remove the `ollama` service from docker-compose.yml.
GEMMA_BASE_URL=http://ollama:11434/v1
GEMMA_MODEL=gemma4:e4b

# ── Compute ──
FURIX_DEVICE=cpu            # cpu | cuda | mps

# ── HTTP ──
FURIX_HTTP_PORT=8088          # host port nginx binds to
FURIX_CORS_ORIGINS=http://localhost

# Source data (host ./deploy/source_data is mounted to /data/source in the api):
#   - scf-full-2026.2.json   (required — SCF crosswalk)
#   - NIST.CSWP.29.pdf       (NIST CSF 2.0, for RAG evidence)
#   - cis_controls_v8.1.pdf  (optional — CIS RAG evidence)
