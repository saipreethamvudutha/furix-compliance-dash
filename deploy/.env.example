# Copy to `.env` in this deploy/ directory and adjust. All have safe defaults.

# ── Database ──
PG_USER=furix
PG_PASSWORD=change-me-in-prod
PG_DBNAME=furix_compliance
PG_DBNAME_DET=furix_det

# ── Gemma / Ollama ──
# In-compose ollama by default. If Ollama runs elsewhere (e.g. your server),
# set this to that host and remove the `ollama` service from docker-compose.yml.
GEMMA_BASE_URL=http://ollama:11434/v1
GEMMA_MODEL=gemma4:e4b

# ── Compute ──
FURIX_DEVICE=cpu            # cpu | cuda | mps

# ── HTTP ──
FURIX_HTTP_PORT=8088          # host port nginx binds to
FURIX_CORS_ORIGINS=http://localhost

# ── Auth & tenancy (FUR-CMP-004) — REQUIRED in production ──
# Every data endpoint needs a bearer key. Provide a JSON list of keys, each with
# a tenant and a role (admin | analyst | auditor | mssp). Generate real random
# keys for prod (e.g. `openssl rand -hex 24`) and give the browser one via
# NEXT_PUBLIC_API_KEY below. FURIX_ENV=production refuses to mint a dev key.
FURIX_ENV=production
FURIX_API_KEYS=[{"key":"CHANGE-ME-generate-a-random-key","key_id":"admin","tenant":"default","role":"admin"}]
# Server-side ONLY (P0-1): the dashboard's BFF attaches this when proxying to
# the API. NEVER a NEXT_PUBLIC_* var — it must not reach the browser.
FURIX_API_KEY=CHANGE-ME-generate-a-random-key
FURIX_TLS_TERMINATED=1            # acknowledge TLS terminates in front of the API (prod preflight)
FURIX_RATE_LIMIT_PER_MIN=240
FURIX_MAX_INGEST_CHARS=20971520   # 20 MB per ingest payload

# ── Dashboard login (BFF identity directory) — REQUIRED to log in ──
# The dashboard container runs NODE_ENV=production (next start), so the built-in
# demo users are DISABLED. To sign in you MUST provide a user directory here (or
# configure OIDC below). Passwords are compared as sha256 hashes.
# Ready-to-use demo directory — logins: admin@byoc.com/admin123,
# analyst@byoc.com/analyst123, auditor@byoc.com/auditor123, mssp@byoc.com/mssp123
# (one per RBAC role, so you can exercise analyst/auditor/mssp access too):
# FURIX_BFF_USERS=[{"email":"admin@byoc.com","passHash":"240be518fabd2724ddb6f04eeb1da5967448d7e831c08c8fa822809f74c720a9","role":"admin","tenant":"default"},{"email":"analyst@byoc.com","passHash":"20249749412d73a3f5799f6f1dcf910e7b4aa3ce4de133b1f8a63c044792a4e9","role":"analyst","tenant":"default"},{"email":"auditor@byoc.com","passHash":"5b92db4dfb561dc69c949f34d36f5db0f8b30811be3a2949d85c5001279e9b1a","role":"auditor","tenant":"default"},{"email":"mssp@byoc.com","passHash":"f3a1ad84e7a2b6a29868607723ebc2b27e5347454aa228f7c4293f308fb1cb6d","role":"mssp","tenant":"default"}]
# Hash a custom password:  printf 'yourpassword' | sha256sum
# FURIX_SESSION_SECRET / FURIX_BFF_MINT_SECRET have dev defaults in compose; set
# real random values beyond a lab (FURIX_BFF_MINT_SECRET MUST equal the api's
# FURIX_OIDC_HS256_SECRET so per-user tokens verify).

# ── OIDC / JWT bearer auth (Wave 4, optional) ──
# When set, Furix also accepts JWTs from your IdP alongside API keys. HS256 uses
# a shared secret (stdlib); RS256/JWKS needs `pip install 'pyjwt[crypto]'`.
# Claims map to a Principal: sub→key_id, tenant claim→tenant, role claim→role.
# FURIX_OIDC_HS256_SECRET=change-me
# FURIX_OIDC_ISSUER=https://your-idp.example
# FURIX_OIDC_AUDIENCE=furix
# FURIX_OIDC_TENANT_CLAIM=tenant
# FURIX_OIDC_ROLE_CLAIM=role
# FURIX_OIDC_JWKS_URL=https://your-idp.example/.well-known/jwks.json

# ── Durability + evidence encryption (Wave 4, optional) ──
# FURIX_JOB_DB: path to a SQLite file → jobs survive restarts (recovered as
#   errored). Omit for in-memory (single-worker) behaviour.
# FURIX_JOB_DB=/data/reports/jobs.db
# FURIX_EVIDENCE_MASTER_KEY: hex/opaque master key → evidence encrypted at rest
#   with a per-tenant AES-256-GCM key (needs `pip install cryptography`).
#   Unset → evidence stored in plaintext (envelope records encrypted:false).
# FURIX_EVIDENCE_MASTER_KEY=

# Source data (host ./deploy/source_data is mounted to /data/source in the api):
#   - scf-full-2026.2.json   (required — SCF crosswalk)
#   - NIST.CSWP.29.pdf       (NIST CSF 2.0, for RAG evidence)
#   - cis_controls_v8.1.pdf  (optional — CIS RAG evidence)
